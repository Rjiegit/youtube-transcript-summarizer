{
  "name": "nuxt-showcase",
  "private": true,
  "type": "module",
  "imports": {
    "#internal/nuxt/paths": "./.nuxt/paths.mjs"
  },
  "scripts": {
    "dev": "node ./scripts/ensure-nuxt-internal-paths.mjs && nuxt dev --port 3000",
    "build": "node ./scripts/ensure-nuxt-internal-paths.mjs && nuxt build && node ./scripts/ensure-nuxt-internal-paths.mjs",
    "preview": "node ./scripts/ensure-nuxt-internal-paths.mjs && nuxt preview",
    "test": "vitest run",
    "check-env": "node ./scripts/check-env.mjs"
  },
  "dependencies": {
    "markdown-it": "^14.2.0",
    "nuxt": "^3.17.7"
  },
  "devDependencies": {
    "@types/markdown-it": "^14.1.2",
    "@vitejs/plugin-vue": "^6.0.1",
    "@vue/test-utils": "^2.4.6",
    "jsdom": "^26.1.0",
    "typescript": "^5.8.3",
    "vitest": "^3.2.4",
    "vue": "^3.5.18"
  }
}
