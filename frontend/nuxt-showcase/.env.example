NOTION_API_KEY=
NOTION_DATABASE_ID=
# 例如 https://www.notion.so/your-workspace
NOTION_URL=
NOTION_STATUS_PROPERTY=
NOTION_COMPLETED_STATUS=Completed
# 展示頁 CDN / server cache TTL，單位秒；預設 3600
SHOWCASE_CACHE_TTL_SECONDS=3600

# 若部署平台偏好使用 Nuxt runtime 覆寫，也可改用這組鍵名：
# NUXT_NOTION_API_KEY=
# NUXT_NOTION_DATABASE_ID=
# NUXT_NOTION_URL=
# NUXT_NOTION_STATUS_PROPERTY=
# NUXT_NOTION_COMPLETED_STATUS=Completed
# NUXT_SHOWCASE_CACHE_TTL_SECONDS=3600
